-- Total Patients
SELECT COUNT(*) AS total_patients FROM patients;

-- Readmission Count
SELECT readmitted, COUNT(*) AS count
FROM patients
GROUP BY readmitted;

-- Average Length of Stay
SELECT AVG(length_of_stay) AS avg_stay
FROM patients;

-- Patients by Diagnosis
SELECT diagnosis, COUNT(*) 
FROM patients
GROUP BY diagnosis;

-- High Risk Patients (LOS > 5)
SELECT * 
FROM patients
WHERE length_of_stay > 5;
